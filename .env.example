# Copy to .env on the Pi and fill in.
#
# Generate the secret once with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# and keep it stable, or every restart will invalidate all sessions.
GSHADOW_SECRET=replace-me-with-a-long-random-hex-string

# Max single-upload size in MB
GSHADOW_MAX_UPLOAD_MB=25

# DEVELOPMENT ONLY. If set to 1, lets requests from 127.0.0.1 reach the
# admin/login/upload routes. NEVER set this on the Pi — Tailscale Funnel
# proxies public traffic through 127.0.0.1, so this would let the public in.
# GSHADOW_ALLOW_LOOPBACK_ADMIN=1
